{
  "version": 1,
  "sdk_version": "0.20.0",
  "path": "/functions/v1/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://ljlhrkzowsbjkqzdvrrw.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "cotacoes-nilo-mcp",
      "version": "0.1.0",
      "title": "Cotações Nilo MCP"
    },
    "tools": [
      {
        "name": "list_cotacoes",
        "title": "Listar cotações",
        "description": "Lista as cotações (listas) do usuário autenticado. Filtra opcionalmente por status.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "status": {
              "type": "string",
              "enum": [
                "aberta",
                "finalizada"
              ],
              "description": "Filtrar por status."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "default": 20
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_cotacao",
        "title": "Detalhar cotação",
        "description": "Retorna detalhes de uma cotação do usuário autenticado, incluindo produtos.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_fornecedores",
        "title": "Listar fornecedores",
        "description": "Lista os fornecedores cadastrados pelo usuário autenticado.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "estado": {
              "type": "string",
              "enum": [
                "MT",
                "GO"
              ]
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200,
              "default": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_respostas",
        "title": "Listar respostas de fornecedores",
        "description": "Lista as respostas de fornecedores para uma cotação do usuário autenticado.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "lista_id": {
              "type": "string",
              "format": "uuid"
            }
          },
          "required": [
            "lista_id"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
